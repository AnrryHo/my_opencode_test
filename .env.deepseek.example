# Copy this file to .env when using public DeepSeek as a temporary model backend.
#
# PowerShell:
#   Copy-Item .env.deepseek.example .env
#
# Do not commit .env. It is ignored by .gitignore.

GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787

# Local key accepted by this gateway. OpenCode uses this value, not your DeepSeek key.
GATEWAY_API_KEY=dev-key

# Model aliases exposed to OpenCode.
GATEWAY_MODELS=dev-fast,dev-balanced,dev-best

# DeepSeek public API currently uses https://api.deepseek.com as the OpenAI-compatible base URL.
# Do not add /v1 here unless DeepSeek changes its official endpoint.
UPSTREAM_BASE_URL=https://api.deepseek.com
UPSTREAM_API_KEY=replace-with-your-deepseek-api-key

# Map OpenCode-friendly aliases to DeepSeek model names.
# As of 2026-06-27, DeepSeek docs list deepseek-v4-flash and deepseek-v4-pro.
GATEWAY_MODEL_MAP=dev-fast=deepseek-v4-flash,dev-balanced=deepseek-v4-flash,dev-best=deepseek-v4-pro

# Low temperature is usually better for coding tasks.
GATEWAY_DEFAULT_TEMPERATURE=0
UPSTREAM_TIMEOUT_MS=120000
