{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "intranet": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Intranet LLM",
      "options": {
        "baseURL": "http://127.0.0.1:8787/v1",
        "apiKey": "{env:INTRANET_LLM_API_KEY}"
      },
      "models": {
        "dev-fast": {
          "name": "Dev Fast"
        },
        "dev-balanced": {
          "name": "Dev Balanced"
        },
        "dev-best": {
          "name": "Dev Best"
        }
      }
    }
  },
  "model": "intranet/dev-balanced",
  "small_model": "intranet/dev-fast",
  "permission": {
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "del /s *": "deny",
      "curl http*": "ask",
      "wget http*": "ask"
    },
    "edit": "ask",
    "webfetch": "deny"
  }
}
