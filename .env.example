# Gateway listen address.
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787

# API key accepted by this gateway. Leave empty to disable auth in local tests.
GATEWAY_API_KEY=dev-key

# Model aliases returned by /v1/models.
GATEWAY_MODELS=dev-fast,dev-balanced,dev-best

# Optional upstream OpenAI-compatible model service.
# Keep empty for mock mode. Fill these after your intranet model service is ready.
UPSTREAM_BASE_URL=
UPSTREAM_API_KEY=

# Request timeout when proxying to the upstream service.
UPSTREAM_TIMEOUT_MS=120000
